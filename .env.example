# Buttondown API key — https://buttondown.com/settings/api
# Leave unset in dev: the signup form runs in a graceful "not configured" mode.
BUTTONDOWN_API_KEY=

# Powers the homepage daily brief, /api/draft-issue, Interview Coach, and
# Radar's Paper Playground
# via Z.ai's GLM models. Leave unset: features degrade gracefully.
ZAI_API_KEY=
# Optional: override the model used for brief/draft generation.
ZAI_MODEL=glm-4.5

# Powers the Naukri (India) listings in Interview Prep's "Open roles" via
# Apify (https://console.apify.com/settings/integrations). Leave unset:
# the section falls back to the free company job boards.
APIFY_TOKEN=

# Canonical site URL used for SEO metadata, RSS, and the sitemap.
NEXT_PUBLIC_SITE_URL=https://ai-brief.example.com
