# Buttondown API key — https://buttondown.com/settings/api
# Leave unset in dev: the signup form runs in a graceful "not configured" mode.
BUTTONDOWN_API_KEY=

# Powers the Interview Coach on /interview-prep. Leave unset to show a
# graceful configuration message locally; never expose this key to the browser.
OPENAI_API_KEY=
# Optional: override the cost-conscious default model used by the coach.
OPENAI_INTERVIEW_COACH_MODEL=gpt-5.4-mini

# Canonical site URL used for SEO metadata, RSS, and the sitemap.
NEXT_PUBLIC_SITE_URL=https://ai-brief.example.com
